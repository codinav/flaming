# ─────────────────────────────────────────────────────────────
# Flaming Integrated Logistiks Ltd — Environment Variables
# Copy to .env (local) / set in your host. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL="https://fill.ng"

# Database
# Local (default): SQLite, zero infra.
DATABASE_URL="file:./dev.db"
# Production: switch prisma/schema.prisma datasource provider to "postgresql"
# and use a Postgres URL, e.g.:
# DATABASE_URL="postgresql://user:password@host:5432/fill?schema=public"

# Admin panel (HTTP Basic Auth on /admin). Set BOTH in production to protect it.
ADMIN_USER=""
ADMIN_PASSWORD=""

# Email notifications (optional — logs if unset). Uses Resend.
RESEND_API_KEY=""
MAIL_FROM="Flaming Logistiks <no-reply@fill.ng>"
MAIL_TO_SALES="sales@fill.ng"

# Integrations (optional, for future features)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
